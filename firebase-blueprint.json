{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the news portal (Admin, Editor, or Reader)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user" },
        "email": { "type": "string", "format": "email", "description": "The email address of the user" },
        "displayName": { "type": "string", "description": "The display name of the user" },
        "role": { "type": "string", "enum": ["admin", "editor", "user"], "description": "The role of the user" },
        "photoURL": { "type": "string", "format": "uri", "description": "The profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" }
      },
      "required": ["uid", "email", "role"]
    },
    "Category": {
      "title": "Category",
      "description": "A news category (e.g., Politics, Sports)",
      "type": "object",
      "properties": {
        "nameNepali": { "type": "string", "description": "The name of the category in Nepali" },
        "nameEnglish": { "type": "string", "description": "The name of the category in English" },
        "slug": { "type": "string", "description": "The URL-friendly slug for the category" },
        "order": { "type": "integer", "description": "The display order of the category" }
      },
      "required": ["nameNepali", "slug"]
    },
    "Article": {
      "title": "Article",
      "description": "A news article",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the article" },
        "content": { "type": "string", "description": "The full content of the article" },
        "excerpt": { "type": "string", "description": "A short summary of the article" },
        "categoryId": { "type": "string", "description": "The ID of the category this article belongs to" },
        "authorId": { "type": "string", "description": "The UID of the author" },
        "authorName": { "type": "string", "description": "The name of the author" },
        "status": { "type": "string", "enum": ["draft", "published"], "description": "The publication status" },
        "featuredImage": { "type": "string", "format": "uri", "description": "The URL of the featured image" },
        "videoUrl": { "type": "string", "format": "uri", "description": "Optional video URL" },
        "views": { "type": "integer", "description": "The number of views" },
        "isBreaking": { "type": "boolean", "description": "Whether this is breaking news" },
        "isFeatured": { "type": "boolean", "description": "Whether this is a featured article" },
        "districts": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of Nepali districts related to this article" 
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the article was created" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the article was last updated" }
      },
      "required": ["title", "content", "categoryId", "authorId", "status"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global site configuration",
      "type": "object",
      "properties": {
        "siteName": { "type": "string", "description": "The name of the site" },
        "logoUrl": { "type": "string", "format": "uri", "description": "The URL of the site logo" },
        "liveVideoUrl": { "type": "string", "format": "uri", "description": "The URL for the live video stream" },
        "liveVideoType": { "type": "string", "enum": ["youtube", "facebook"], "description": "The type of live video stream" },
        "contactEmail": { "type": "string", "format": "email", "description": "Contact email address" },
        "facebookUrl": { "type": "string", "format": "uri", "description": "Facebook page URL" },
        "twitterUrl": { "type": "string", "format": "uri", "description": "Twitter profile URL" },
        "youtubeUrl": { "type": "string", "format": "uri", "description": "YouTube channel URL" }
      }
    },
    "LiveChat": {
      "title": "Live Chat",
      "description": "Messages sent in the live chat",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The UID of the sender" },
        "user": { "type": "string", "description": "The name of the sender" },
        "text": { "type": "string", "description": "The message text" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent" },
        "isSponsored": { "type": "boolean", "description": "Whether this is a sponsored message" }
      },
      "required": ["uid", "user", "text", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on an article",
      "type": "object",
      "properties": {
        "articleId": { "type": "string", "description": "The ID of the article" },
        "userName": { "type": "string", "description": "The name of the commenter" },
        "content": { "type": "string", "description": "The comment text" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the comment was posted" }
      },
      "required": ["articleId", "userName", "content", "createdAt"]
    },
    "Ad": {
      "title": "Advertisement",
      "description": "An advertisement banner",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the ad" },
        "imageUrl": { "type": "string", "format": "uri", "description": "The URL of the ad image" },
        "linkUrl": { "type": "string", "format": "uri", "description": "The URL the ad links to" },
        "position": { "type": "string", "enum": ["top", "sidebar", "middle", "bottom"], "description": "The position of the ad" },
        "active": { "type": "boolean", "description": "Whether the ad is active" }
      },
      "required": ["title", "imageUrl", "position"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A system notification",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The notification title" },
        "message": { "type": "string", "description": "The notification message" },
        "type": { "type": "string", "enum": ["info", "success", "error", "warning"], "description": "The type of notification" },
        "isRead": { "type": "boolean", "description": "Whether the notification has been read" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the notification was created" },
        "articleId": { "type": "string", "description": "Optional related article ID" }
      },
      "required": ["title", "message", "type", "isRead", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/categories/{categoryId}": { "schema": "Category", "description": "News categories" },
    "/articles/{articleId}": { "schema": "Article", "description": "News articles" },
    "/settings/{settingId}": { "schema": "SiteSettings", "description": "Global site settings" },
    "/liveChat/{messageId}": { "schema": "LiveChat", "description": "Live chat messages" },
    "/comments/{commentId}": { "schema": "Comment", "description": "Article comments" },
    "/ads/{adId}": { "schema": "Ad", "description": "Advertisements" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "System notifications" }
  }
}
